            </iframe>
        </div>
    </div>
</div>

<footer class="app-footer">
    <div class="footer-content">
        <div class="footer-copyright">
            &copy;2026 - 221st Street Music LLC.<br>
            All rights reserved.
        </div>
        <a href="https://221street.com/" style="display: contents;">
            <img src="logo.png" alt="221st Street Publishing" class="footer-logo" onerror="this.style.display='none';">
        </a>
        <div class="footer-contact">
            <strong>Contact us:</strong><br>
            918.607.3046<br>
            <a href="mailto:info@221street.com">info@221street.com</a>
        </div>
    </div>
</footer>

</body>
</html>
